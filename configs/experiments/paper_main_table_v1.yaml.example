# Unique formal experiment manifest for paper main-table baselines.
# Merge order per method: base_config → shared_model_config → method config.
#
# freeze_status: provisional until real shared-LLM DEV trials + selection evidence exist.

schema_version: firebench-interop-v1
experiment_id: paper_main_table_baselines_v1
track: A_shared_outcome
freeze_status: provisional
paper_final: false
require_bundle_checksum: true

# Set after main project exports the formal Runner Bundle:
bundle: path/to/runner_bundle

base_config: configs/default.yaml
shared_model_config: configs/shared_real_model.yaml

main_table_methods:
  - direct_llm
  - bm25_rag
  - ekell_style_faithful

supplemental_methods:
  - dense_rag
  - hybrid_rag
  - ekell_style_enhanced

methods:
  - method_id: direct_llm
    config: configs/frozen/direct_llm_v1.yaml
    paper_table_role: main_table
    enabled: true
  - method_id: bm25_rag
    config: configs/frozen/bm25_rag_v1.yaml
    paper_table_role: main_table
    enabled: true
  - method_id: ekell_style_faithful
    config: configs/frozen/ekell_style_faithful_v1.yaml
    paper_table_role: main_table
    enabled: true
  # Supplemental / extended — disabled by default; do not replace faithful results.
  - method_id: dense_rag
    config: configs/frozen/dense_rag_v1.yaml
    paper_table_role: supplemental_extended
    enabled: false
  - method_id: hybrid_rag
    config: configs/frozen/hybrid_rag_v1.yaml
    paper_table_role: supplemental_extended
    enabled: false
  - method_id: ekell_style_enhanced
    config: configs/frozen/ekell_style_enhanced_v1.yaml
    paper_table_role: supplemental_extended
    enabled: false

output: outputs/firebench_interop_v1_predictions.jsonl
legacy_output: outputs/baseline_outputs_legacy.jsonl
run_manifest: outputs/interop_run_manifest.json

notes:
  - Main paper table baselines are only direct_llm, bm25_rag, ekell_style_faithful.
  - dense_rag / hybrid_rag / ekell_style_enhanced are supplemental and must not replace faithful.
  - configs/frozen/* are provisional until DEV trial logs + selection criterion evidence are attached.
  - Do not run paid APIs from CI; user runs after SILICONFLOW_API_KEY is set.
  - cross_repository_interop_verified remains false until formal Runner Bundle is consumed.
