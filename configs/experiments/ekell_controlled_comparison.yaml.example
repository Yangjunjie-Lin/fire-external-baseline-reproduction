schema_version: firebench-interop-v1
experiment_id: ekell_controlled_comparison_v1
track: A_shared_outcome
freeze_status: provisional
paper_final: false
require_bundle_checksum: true
expected_bundle_checksum: REPLACE_AFTER_FORMAL_RUNNER_BUNDLE

bundle: path/to/formal_runner_bundle

base_config: configs/default.yaml
shared_model_config: configs/models/siliconflow_shared.yaml.example

main_table_methods:
  - direct_llm
  - bm25_rag
  - ekell_style_controlled_shared_llm

methods:
  - method_id: direct_llm
    config: configs/frozen/direct_llm_v1.yaml
    paper_table_role: main_table
    enabled: true
  - method_id: bm25_rag
    config: configs/frozen/bm25_rag_v1.yaml
    paper_table_role: main_table
    enabled: true
  - method_id: ekell_style_controlled_shared_llm
    config: configs/ekell_controlled_shared_llm.yaml.example
    paper_table_role: main_table
    enabled: true
  - method_id: ekell_style_enhanced
    config: configs/frozen/ekell_style_enhanced_v1.yaml
    paper_table_role: supplemental_extended
    enabled: false

output: outputs/firebench_interop_v1_predictions.jsonl
notes:
  - Controlled track keeps E-KELL architecture; shares SiliconFlow LLM with main project
  - Does not claim official E-KELL results
  - cross_repository_interop_verified=false until formal Runner Bundle is consumed
