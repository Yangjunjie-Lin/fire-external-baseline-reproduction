# Formal controlled main-table experiment manifest (single source of truth).
# Copy to configs/experiments/controlled_main_table_v1.yaml before running.
# Merge order per method: base_config → shared_model_config → method config.

schema_version: firebench-interop-v1
experiment_id: controlled_main_table_v1
track: A_shared_outcome
run_mode: formal
freeze_status: provisional
paper_final: true

bundle: path/to/runner_bundle

base_config: configs/default.yaml
shared_model_config: configs/models/shared_real_model.yaml.example

require_bundle_checksum: true
require_external_schema: true
require_complete_case_match: true
fail_on_schema_error: true
fail_on_duplicate_case_id: true
fail_on_missing_case: true
fail_on_extra_case: true

main_table_methods:
  - direct_llm
  - bm25_rag
  - ekell_style_controlled_shared_llm

supplemental_methods:
  - dense_rag
  - hybrid_rag
  - ekell_style_enhanced

methods:
  - method_id: direct_llm
    paper_table_role: main_table
    config: configs/frozen/direct_llm_v1.yaml
    enabled: true
  - method_id: bm25_rag
    paper_table_role: main_table
    config: configs/frozen/bm25_rag_v1.yaml
    enabled: true
  - method_id: ekell_style_controlled_shared_llm
    paper_table_role: main_table
    config: configs/frozen/ekell_controlled_shared_llm_v1.yaml
    enabled: true
  - method_id: dense_rag
    paper_table_role: supplemental_extended
    config: configs/frozen/dense_rag_v1.yaml
    enabled: false
  - method_id: hybrid_rag
    paper_table_role: supplemental_extended
    config: configs/frozen/hybrid_rag_v1.yaml
    enabled: false
  - method_id: ekell_style_enhanced
    paper_table_role: supplemental_extended
    config: configs/frozen/ekell_style_enhanced_v1.yaml
    enabled: false

output: outputs/interop/controlled_main_table_v1/predictions.jsonl
legacy_output: outputs/legacy/baseline_outputs_legacy.jsonl
run_manifest: outputs/interop/controlled_main_table_v1/run_manifest.json

notes:
  - Canonical main-table IDs only; ekell_style_faithful is a CLI alias only.
  - Replace ekell_vector placeholders before formal run; validator hard-fails otherwise.
  - freeze_status remains provisional until DEV evidence + real shared-LLM runs exist.
  - Do not run paid APIs from CI.
