# Shared SiliconFlow LLM config aligned with fire-agent-demo.
# Copy to configs/shared_real_model.yaml (gitignored locally if desired) and set env vars.
# NEVER commit API keys.
#
# Required env (same names as fire-agent-demo/.env.example):
#   SILICONFLOW_API_KEY=...
#   SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1   # optional override
#   SILICONFLOW_MODEL=deepseek-ai/DeepSeek-R1-0528-Qwen3-8B  # optional override
#
# Fallback env names also accepted by the client: LLM_API_KEY, OPENAI_API_KEY

paper_final: false
require_bundle_checksum: true

llm:
  provider: siliconflow
  model: deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
  model_version: deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
  api_key_env: SILICONFLOW_API_KEY
  base_url_env: SILICONFLOW_BASE_URL
  temperature: 0.2
  top_p: 1.0
  max_tokens: 1200
  seed: 7
  connect_timeout_sec: 10
  read_timeout_sec: 120
  write_timeout_sec: 20
  max_retries: 0
  enable_thinking: false

normalization:
  infer_structured_safety_fields: false
