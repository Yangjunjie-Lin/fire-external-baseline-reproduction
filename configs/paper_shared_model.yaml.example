# Alias pointing at shared model example for docs/commands.
# Prefer copying shared_real_model.yaml.example → shared_real_model.yaml locally.
paper_final: false
llm:
  provider: openai
  model: REPLACE_WITH_SHARED_MODEL_NAME
  model_version: REPLACE_WITH_MODEL_VERSION
  temperature: 0.0
  top_p: 1.0
  max_tokens: 1200
  seed: 7
normalization:
  infer_structured_safety_fields: false
