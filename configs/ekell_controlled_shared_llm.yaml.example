# Controlled comparison E-KELL method config (shared LLM with main project).
method_id: ekell_style_controlled_shared_llm
track: controlled_shared_llm
paper_original_output_format: false
controlled_output_format: true
official_reproduction: false
freeze_status: provisional

scenario_parser:
  use_llm: true

ekell_style:
  prompt_dir: configs/prompts/paper_fidelity
  neighborhood_k_hop: 1
  neighborhood_max_nodes: 50
  neighborhood_max_triples: 80

ekell_vector:
  backend: smoke  # replace with agreed shared embedding for formal runs
  model_name: deterministic-hash-smoke
  dimension: 64
  reject_smoke: false
  top_k: 8

normalization:
  infer_structured_safety_fields: false

