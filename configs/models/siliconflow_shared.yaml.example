# Shared SiliconFlow model aligned with fire-agent-demo (controlled comparison).
paper_final: false
require_bundle_checksum: true

llm:
  provider: siliconflow
  model: deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
  model_version: deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
  api_key_env: SILICONFLOW_API_KEY
  base_url_env: SILICONFLOW_BASE_URL
  temperature: 0.2
  top_p: 1.0
  max_tokens: 1200
  seed: 7
  connect_timeout_sec: 10
  read_timeout_sec: 120
  write_timeout_sec: 20
  max_retries: 0
  enable_thinking: false

ekell_vector:
  backend: text2vec
  model_name: REPLACE_WITH_SHARED_EMBEDDING_IF_AGREED
  model_version: REPLACE
  reject_smoke: true
  top_k: 8

normalization:
  infer_structured_safety_fields: false
