# Shared SiliconFlow LLM config aligned with fire-agent-demo.
# Copy to configs/models/shared_real_model.yaml and set env vars.
# NEVER commit API keys.
# Formal model identity comes from this YAML (not SILICONFLOW_MODEL).
# This template is a paper candidate only; final identity is selected on DEV,
# frozen in a complete manifest, and reviewed before Formal TEST.
paper_final: false
require_bundle_checksum: true

llm:
  provider: siliconflow
  model: deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
  model_version: deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
  allow_model_env_override: false
  api_key_env: SILICONFLOW_API_KEY
  base_url_env: SILICONFLOW_BASE_URL
  temperature: 0.0
  top_p: 1.0
  max_tokens: 1200
  seed: 7
  connect_timeout_sec: 10
  read_timeout_sec: 120
  write_timeout_sec: 20
  max_retries: 1
  enable_thinking: false

normalization:
  infer_structured_safety_fields: false
