# SiliconFlow / shared-model env template (aligned with fire-agent-demo).
# Option A: copy to .env in this repo root.
# Option B (default for local dev): keep credentials only in ../fire-agent-demo/.env;
#     load_local_environment() loads that file automatically (override=False).
# Option C: set FIRE_AGENT_DEMO_ENV_PATH to an absolute .env path.
#
# Formal model identity is frozen in YAML configuration.
# Environment variables provide credentials and endpoint settings only.
# SILICONFLOW_MODEL is deprecated for formal runs and does not silently override YAML.

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# Deprecated for formal runs — YAML llm.model is authoritative:
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-R1-0528-Qwen3-8B

# Optional aliases accepted by the baseline client:
# LLM_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
LLM_CONNECT_TIMEOUT_SECONDS=10
LLM_READ_TIMEOUT_SECONDS=120
LLM_WRITE_TIMEOUT_SECONDS=20
LLM_STREAM=0
LLM_ENABLE_THINKING=false
