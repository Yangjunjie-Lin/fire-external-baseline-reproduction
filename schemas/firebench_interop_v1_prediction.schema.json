{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firebench.local/schemas/firebench_interop_v1/prediction_schema.json",
  "title": "FireBench Interop v1 Prediction",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "case_id",
    "method_id",
    "prediction",
    "runtime",
    "provenance",
    "method_metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "firebench-interop-v1"
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "method_id": {
      "type": "string",
      "minLength": 1
    },
    "prediction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "risk_signals",
        "risk_level",
        "recommended_actions",
        "blocked_actions",
        "missing_confirmations",
        "evidence_refs",
        "human_review_required",
        "final_decision_gate",
        "final_response"
      ],
      "properties": {
        "risk_signals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "critical",
            "unknown"
          ]
        },
        "recommended_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "action_id",
              "text",
              "priority",
              "evidence_refs"
            ],
            "properties": {
              "action_id": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string"
              },
              "priority": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical",
                  "unknown"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "missing_confirmations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "evidence_id"
            ],
            "properties": {
              "evidence_id": {
                "type": "string",
                "minLength": 1
              },
              "source_id": {
                "type": "string"
              },
              "chunk_id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "topic": {
                "type": "string"
              },
              "content_hash": {
                "type": "string"
              }
            }
          }
        },
        "human_review_required": {
          "type": "boolean"
        },
        "final_decision_gate": {
          "type": "string",
          "enum": [
            "allow_response",
            "await_human_confirmation",
            "block_response",
            "unknown"
          ]
        },
        "final_response": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "status",
            "text",
            "citations",
            "real_world_execution_allowed"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "provided",
                "awaiting_human_confirmation",
                "blocked",
                "not_applicable",
                "unknown"
              ]
            },
            "text": {
              "type": "string"
            },
            "citations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "real_world_execution_allowed": {
              "const": false
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "latency_ms",
        "llm_calls",
        "token_usage",
        "cost"
      ],
      "properties": {
        "latency_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "llm_calls": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "integer",
              "number",
              "null"
            ],
            "minimum": 0
          }
        },
        "cost": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "method_metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
